# Compiled class files
*.class

# Maven
/target/

# Gradle
/.gradle/
/build/

# Eclipse
.classpath
.project
.settings/

# IntelliJ
/.idea/
*.iml

# VS Code
/.vscode/

# Spring Boot specific
# Exclude executable jars and exploded app builds
*.jar
*.war
*.ear

# Logs
*.log
logs/

# JVM crash logs
hs_err_pid*

# Package distribution
*.tar.gz
*.zip

# -------------------------
# Node / React
# -------------------------
# dependencies
node_modules/

# build output
/frontend/build/
/build/
/dist/

# misc
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# dotenv environment variables
.env
.env.*.local
.env.local

# test coverage
/coverage/

# Editor directories and files
*.suo
*.ntvs*
*.njsproj
*.sln
.DS_Store
Thumbs.db

# OS generated files
._*
.Spotlight-V100
.Trashes
ehthumbs.db

# Lockfiles (optional to keep in repo)
# package-lock.json
# yarn.lock

# IDE / build tool wrappers - keep wrapper jars if you prefer committing them
!gradle/wrapper/gradle-wrapper.jar
!mvnw
!mvnw.cmd

# Optional: ignore built frontend artifacts inside project subfolders
**/node_modules/
**/dist/
**/build/

# Editor swap files
*~
*.swp

